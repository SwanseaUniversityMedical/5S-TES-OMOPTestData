# Copy this file to .env and edit as needed

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=synthea
POSTGRES_USER=synthea
POSTGRES_PASSWORD=synthea_secret_change_me
POSTGRES_PORT=5432

# ── Synthea CSV source ────────────────────────────────────────────────────────
# Full path to the folder containing your Synthea CSV files on the HOST machine
# Windows example:  CSV_SOURCE_DIR=C:/temp/synthea/Synthea-Docker/output/csv
# Linux/Mac:        CSV_SOURCE_DIR=/data/synthea/csv
CSV_SOURCE_DIR=C:/temp/synthea/Synthea-Docker/output/csv

# ── OMOP Vocabulary ───────────────────────────────────────────────────────────
# Download from https://athena.ohdsi.org (free account required).
# Select at minimum: SNOMED, RxNorm, LOINC, CVX, ICD10CM, ICD9CM, NDC
# Extract the zip and point this at the folder containing CONCEPT.csv etc.
VOCAB_SOURCE_DIR=C:/temp/synthea/Vocabulary

# ── OMOP ETL settings ─────────────────────────────────────────────────────────
# Schema names inside the PostgreSQL database
OMOP_CDM_SCHEMA=cdm_synthea
OMOP_NATIVE_SCHEMA=native

# CDM version: "5.3" or "5.4"
OMOP_CDM_VERSION=5.4

# Synthea version that generated your CSVs
# Supported: 2.7.0, 3.0.0, 3.1.0, 3.2.0, 3.3.0
OMOP_SYNTHEA_VERSION=3.3.0
